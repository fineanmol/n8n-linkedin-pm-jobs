# ── n8n ────────────────────────────────────────────────────────────────────────
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Berlin

# n8n basic auth (change these!)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ── Configure these INSIDE n8n → ⚙️ Config node (NOT here) ────────────────────
# searchQueries          → comma-separated job titles to search
# searchLocation         → city/country e.g. Germany, Berlin, Remote
# pmKeywords             → comma-separated role relevance keywords
# englishOnly            → true / false
# proxyUrl               → http://linkedin-proxy:9877/fetch  (leave as-is for Docker)
# spreadsheetId          → Google Sheet ID from URL
# yourEmail              → where digest emails are sent
# openAiApiKey           → sk-...  (for resume optimisation)
# apifyApiKey            → apify_api_...  (for Easy Apply bot)
# resumeDocId            → Google Docs ID of your resume
